# Comma-separated list of WHMCS store/category pages to watch
URLS=https://example.com/index.php?rp=/store/group-a,https://example.com/index.php?rp=/store/group-b

# Telegram bot
TG_TOKEN=123456:ABCDEF
CHAT_ID=123456789

# Optional: only watch products whose title contains this substring (leave empty to watch all)
KEYWORD=

# Optional: poll interval in milliseconds (default 1800000 = 30 min)
INTERVAL_MS=1800000

# Optional: per-product re-notify cooldown in milliseconds (default 1800000 = 30 min)
RENOTIFY_COOLDOWN_MS=1800000

# Optional: override User-Agent
# USER_AGENT=Mozilla/5.0 ...
